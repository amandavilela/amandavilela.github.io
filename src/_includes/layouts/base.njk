<!doctype html>
<html lang="en">
    <head>
        <title>{{ title }}{% if page.url != '/' %} | Amanda Vilela | Frontend Specialist{% endif %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta charset="UTF-8" />
        <link rel="shortcut icon" href="/favicon.ico" />

        <style>
            {{ "dist/critical.css" | read_file | cssmin | safe }}
            {% if page.url == '/' %}{{ "dist/home_critical.css" | read_file | cssmin | safe }}{% endif %}
            {% if page.url != '/' and page.url != '/404/' %}{{ "dist/header.css" | read_file | cssmin | safe }}{% endif %}
        </style>

        {% if page_css %}
            <link rel="stylesheet" href="/{{ page_css }}.css" />
        {% endif %}

        <meta name="description" content="{{ description }}" />
        {% if keywords %}
            <meta name="keywords" content="{{ keywords }}" />
        {% endif %}

        <meta name="author" content="Amanda Vilela">

        {% if open_graph %}
            <meta property="og:image" content="https://amandavilela.me/{{ open_graph.image }}" />
        {% endif %}

        <link rel="canonical" href="https://amandavilela.me{{ page.url }}" />

        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@graph": [
                {% if page.url == '/' %}
                {
                    "@type": "WebSite",
                    "name": "Amanda Vilela",
                    "url": "https://amandavilela.me/"
                },
                {
                    "@type": "Person",
                    "name": "Amanda Vilela",
                    "url": "https://amandavilela.me/",
                    "jobTitle": "Frontend Specialist",
                    "sameAs": [
                        "https://br.linkedin.com/in/amanda-vilela",
                        "https://github.com/amandavilela",
                        "http://codepen.io/amandavilela/",
                        "https://speakerdeck.com/amandavilela",
                        "https://medium.com/@amandavilela"
                    ]
                }
                {% elif page.url != '/404/' %}
                {
                    "@type": "BreadcrumbList",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Home",
                            "item": "https://amandavilela.me/"
                        }
                        {% if '/blog/' in page.url %}
                            {% if page.url == '/blog/' %}
                            ,{
                                "@type": "ListItem",
                                "position": 2,
                                "name": "{{ title | breadcrumbTitle }}",
                                "item": "https://amandavilela.me/blog/"
                            }
                            {% else %}
                            ,{
                                "@type": "ListItem",
                                "position": 2,
                                "name": "Blog",
                                "item": "https://amandavilela.me/blog/"
                            },
                            {
                                "@type": "ListItem",
                                "position": 3,
                                "name": "{{ title | breadcrumbTitle }}",
                                "item": "https://amandavilela.me{{ page.url }}"
                            }
                            {% endif %}
                        {% elif '/services/' in page.url %}
                            ,{
                                "@type": "ListItem",
                                "position": 2,
                                "name": "{{ title | breadcrumbTitle }}",
                                "item": "https://amandavilela.me/services/"
                            }
                        {% endif %}
                    ]
                }
                {% endif %}
            ]
        }
        </script>

        <!-- Google tag (gtag.js) -->
        <script>
            if (window.location.hostname !== 'localhost') {
                const script = document.createElement('script');
                script.src = 'https://www.googletagmanager.com/gtag/js?id=G-GSM2PDRLRD';
                script.async = true;
                script.onload = () => {
                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    gtag('js', new Date());

                    gtag('config', 'G-GSM2PDRLRD');
                };

                document.head.appendChild(script);
            }
        </script>
    </head>
    <body>
        <a class="skip-link u-focus-ring" href="#main-content">Skip to main content</a>

        {% if page.url != '/' and page.url != '/404/' %}
            <header class="header">
                <div class="container container--flex">
                    <a class="logo u-focus-ring" href="/">Amanda Vilela</a>
                    <nav>
                        <ul class="nav">
                            <li><a class="link u-slide-hover u-focus-ring" href="/">Home</a></li>
                            <li><a class="link u-slide-hover u-focus-ring" href="/services/">Services</a></li>
                            <li><a class="link u-slide-hover u-focus-ring" href="/blog/">Blog</a></li>
                        </ul>
                    </nav>
                </div>
            </header>

            <nav aria-label="Breadcrumb" class="breadcrumbs">
                <div class="container">
                    <ol class="list">
                        <li class="item">
                            <a href="/" class="link u-focus-ring">Home</a>
                        </li>
                        {% if '/blog/' in page.url %}
                            {% if page.url == '/blog/' %}
                                <li class="item" aria-current="page">{{ title | breadcrumbTitle }}</li>
                            {% else %}
                                <li class="item">
                                    <a href="/blog/" class="link u-focus-ring">Blog</a>
                                </li>
                                <li class="item" aria-current="page">{{ title | breadcrumbTitle }}</li>
                            {% endif %}
                        {% elif '/services/' in page.url %}
                             <li class="item" aria-current="page">{{ title | breadcrumbTitle }}</li>
                        {% endif %}
                    </ol>
                </div>
            </nav>
        {% endif %}

        {{ content | safe }}

        {% if page.url != '/404/' %}
            <footer class="footer" id="find-me">
                <div class="container">
                    <h2 class="title">Find me online</h2>
                    <ul class="social">
                        <li>
                            <a
                                class="link u-slide-hover"
                                href="https://br.linkedin.com/in/amanda-vilela"
                                target="_blank"
                                rel="noopener noreferrer"
                                >LinkedIn</a
                            >
                        </li>
                        <li>
                            <a
                                class="link u-slide-hover"
                                href="https://github.com/amandavilela"
                                target="_blank"
                                rel="noopener noreferrer"
                                >GitHub</a
                            >
                        </li>
                        <li>
                            <a
                                class="link u-slide-hover"
                                href="http://codepen.io/amandavilela/"
                                target="_blank"
                                rel="noopener noreferrer"
                                >Codepen</a
                            >
                        </li>
                        <li>
                            <a
                                class="link u-slide-hover"
                                href="https://speakerdeck.com/amandavilela"
                                target="_blank"
                                rel="noopener noreferrer"
                                >Speakerdeck</a
                            >
                        </li>
                        <li>
                            <a
                                class="link u-slide-hover"
                                href="https://medium.com/@amandavilela"
                                target="_blank"
                                rel="noopener noreferrer"
                                >Medium</a
                            >
                        </li>
                    </ul>
                </div>
            </footer>
        {% endif %}
        <div class="footer-credit">designed and coded by Amanda Vilela</div>
    </body>
</html>
