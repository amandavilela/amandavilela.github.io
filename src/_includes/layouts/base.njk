<!doctype html>
<html lang="en">
    <head>
        <title>{{ title }}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta charset="UTF-8" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css"
            crossorigin
        />
        <link rel="stylesheet" href="/style.css" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;700&family=Merriweather:ital,wght@1,700;1,900&display=swap"
            rel="stylesheet"
        />

        <meta name="description" content="{{ description }}" />
        {% if keywords %}
        <meta name="keywords" content="{{ keywords }}" />
        {% endif %}

        {% if ogTitle %}
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:url" content="{{ ogUrl }}" />
        <meta property="og:title" content="{{ ogTitle }}" />
        <meta property="og:site_name" content="Amanda Vilela" />
        <meta property="og:description" content="{{ ogDescription }}" />
        {% endif %}
    </head>
    <body>
        <a class="skip-link" href="#main-content">Skip to main content</a>

        {{ content | safe }}

        <footer class="footer" id="find-me">
            <div class="container">
                <h2 class="footer__title">Find me online</h2>
                <ul class="social" role="list">
                    <li>
                        <a
                            class="social__link"
                            href="https://br.linkedin.com/in/amanda-vilela"
                            target="_blank"
                            rel="noopener noreferrer"
                            >LinkedIn</a
                        >
                    </li>
                    <li>
                        <a
                            class="social__link"
                            href="https://github.com/amandavilela"
                            target="_blank"
                            rel="noopener noreferrer"
                            >GitHub</a
                        >
                    </li>
                    <li>
                        <a
                            class="social__link"
                            href="http://codepen.io/amandavilela/"
                            target="_blank"
                            rel="noopener noreferrer"
                            >Codepen</a
                        >
                    </li>
                    <li>
                        <a
                            class="social__link"
                            href="https://speakerdeck.com/amandavilela"
                            target="_blank"
                            rel="noopener noreferrer"
                            >Speakerdeck</a
                        >
                    </li>
                    <li>
                        <a
                            class="social__link"
                            href="https://medium.com/@amandavilela"
                            target="_blank"
                            rel="noopener noreferrer"
                            >Medium</a
                        >
                    </li>
                </ul>
            </div>
        </footer>
        <div class="footer-credit">designed and coded by Amanda Vilela</div>
    </body>
</html>
