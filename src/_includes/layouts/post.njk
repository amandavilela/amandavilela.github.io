---
layout: layouts/base.njk
---

<main id="main-content">
    <article class="post__container">
        <header class="post__header">
            <h1>{{ title }}</h1>
            <time class="post__date" datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
        </header>
        <section class="post__body">
            {{ content | safe }}
        </section>
    </article>
</main>
