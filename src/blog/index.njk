---
layout: layouts/base.njk
title: "Blog | Amanda Vilela"
description: "Thoughts on frontend performance, accessibility, and software engineering."
page_css: blog
---

<main id="main-content">
    <section aria-label="Posts">
        <div class="container">
            <h1>Blog</h1>
            <p>Thoughts on frontend performance, accessibility, and software engineering.</p>

            {% if collections.posts.length %}
            <ul class="post-list" role="list">
                {% for post in collections.posts %}
                <li class="post-list__item">
                    <article>
                        <h2>
                            <a href="{{ post.url }}">{{ post.data.title }}</a>
                        </h2>
                        <time class="post__date" datetime="{{ post.date | htmlDateString }}">
                            {{ post.date | readableDate }}
                        </time>
                        {% if post.data.description %}
                        <p>{{ post.data.description }}</p>
                        {% endif %}
                    </article>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p>No posts yet. Check back soon.</p>
            {% endif %}
        </div>
    </section>
</main>
