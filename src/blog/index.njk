---
layout: layouts/base.njk
title: "Blog | Amanda Vilela"
description: "Thoughts on frontend performance, accessibility, and software engineering."
page_css: blog
---

<main id="main-content">
    <section aria-label="Posts">
        <div class="container">
            <h1>Blog</h1>
            <p>Thoughts on frontend performance, accessibility, and software engineering.</p>

            {% if collections.posts.length %}
                <ul class="blog-list" itemscope itemtype="https://schema.org/Blog">
                    {% for post in collections.posts %}
                        <li class="item">
                            <article class="post-summary" itemscope itemtype="https://schema.org/BlogPosting">
                                <h2 class="post-summary__title" itemprop="headline">
                                    <a class="post-summary__link u-slide-hover u-focus-ring" href="{{ post.url }}">{{ post.data.title }}</a>
                                </h2>
                                <time class="post-summary__date" itemprop="datePublished" datetime="{{ post.date | htmlDateString }}">
                                    {{ post.date | readableDate }}
                                </time>
                                {% if post.data.description %}
                                    <p class="post-summary__description" itemprop="description">{{ post.data.description }}</p>
                                {% endif %}
                            </article>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No posts yet. Check back soon.</p>
            {% endif %}
        </div>
    </section>
</main>
