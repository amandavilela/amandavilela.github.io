---
layout: layouts/base.njk
title: "Web Performance & Accessibility Insights"
description: "Technical writing on frontend performance, accessibility, Core Web Vitals, and scalable frontend."
page_css: blog
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "https://amandavilela.me/blog/",
      "name": "Amanda Vilela's Blog",
      "description": "{{ description | replace('"', '\\"') }}",
      "url": "https://amandavilela.me/blog/",
      "publisher": {
        "@type": "Person",
        "@id": "https://amandavilela.me/",
        "name": "Amanda Vilela",
        "url": "https://amandavilela.me/"
      }
    },
    {
      "@type": "ItemList",
      "name": "Blog Posts",
      "itemListElement": [
        {% for post in collections.posts %}
        {
          "@type": "ListItem",
          "position": {{ loop.index }},
          "url": "https://amandavilela.me{{ post.url }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  ]
}
</script>

<main id="main-content">
    <section class="blog">
        <div class="container">
            <h1 class="section-title">Blog</h1>
            <p>Technical writing on frontend performance, accessibility, Core Web Vitals, and scalable frontend.</p>

            {% set allTags = collections.posts | getAllTags %}
            {% if allTags.length %}
                <nav class="tag-filter" aria-label="Filter posts by tag">
                    Tags: {% for tag in allTags %}
                        <a class="tag-filter-button" href="/tags/{{ tag | slugify }}/">{{ tag }}</a>
                    {% endfor %}
                </nav>
            {% endif %}

            {% if collections.posts.length %}
                <ul class="blog-list">
                    {% for post in collections.posts %}
                        <li class="item">
                            <article class="post-summary">
                                <h2 class="title">
                                    <a class="link u-slide-hover u-focus-ring" href="{{ post.url }}">{{ post.data.title }}</a>
                                </h2>
                                <p class="meta">
                                    <time class="date" datetime="{{ post.date | htmlDateString }}">
                                        {{ post.date | readableDate }}
                                    </time> by <a href="/" rel="author">Amanda Vilela</a>
                                </p>
                                {% if post.data.description %}
                                    <p class="description">{{ post.data.description }}</p>
                                {% endif %}
                            </article>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No posts yet. Check back soon.</p>
            {% endif %}
        </div>
    </section>
</main>
